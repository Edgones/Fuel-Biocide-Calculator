# Firebase Cloud Firestore Configuration Template
# -------------------------------------------------------------------------
# OBSERVAÇÃO PARA IMPLANTAÇÃO (GITHUB PAGES):
# Como esta aplicação roda puramente no cliente (frontend estático), estas 
# credenciais serão inseridas diretamente no seu arquivo de inicialização 
# ou injetadas via script de build. Mantenha este arquivo apenas como 
# referência de infraestrutura do projeto.
# -------------------------------------------------------------------------

FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID
